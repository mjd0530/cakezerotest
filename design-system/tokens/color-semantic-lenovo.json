        "value": "{primitive.lenovo.neutral.100}",
        "type": "color",
        "description": "Lenovo: dividers, hairlines."
      },
      "default": {
        "value": "{primitive.lenovo.neutral.200}",
        "type": "color",
        "description": "Lenovo: input borders."
      },
      "strong": {
        "value": "{primitive.lenovo.primary.800}",
        "type": "color",
        "description": "Lenovo: emphasized edges."
      },
      "focus": {
        "value": "{primitive.lenovo.primary.600}",
        "type": "color",
        "description": "Lenovo: focus ring color (pair with lenovo.primary.200 for ring spread)."
      },
      "brand": {
        "value": "{primitive.lenovo.primary.100}",
        "type": "color",
        "description": "Lenovo: brand card borders."
      }
    },
    "link": {
