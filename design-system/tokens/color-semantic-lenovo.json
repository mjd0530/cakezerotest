        "value": "{primitive.lenovo.secondary.600}",
        "type": "color",
        "description": "Lenovo: inline link default (alias of text.link)."
      },
      "hover": {
        "value": "{primitive.lenovo.secondary.900}",
        "type": "color",
        "description": "Lenovo: inline link hover."
      }
    },
    "interactive": {
      "primary": {
        "value": "{primitive.lenovo.primary.600}",
        "type": "color",
        "description": "Lenovo: filled primary CTA background."
      },
      "primaryHover": {
        "value": "{primitive.lenovo.primary.800}",
        "type": "color",
        "description": "Lenovo: primary CTA hover."
      },
      "primaryActive": {
        "value": "{primitive.lenovo.primary.900}",
        "type": "color",
        "description": "Lenovo: primary CTA pressed."
      },
      "primarySubtle": {
        "value": "{primitive.lenovo.primary.50}",
        "type": "color",
        "description": "Lenovo: ghost/subtle primary fill."
      },
      "primaryText": {
        "value": "{primitive.common.white}",
        "type": "color",
        "description": "Lenovo: label on primary CTA."
      },
      "secondary": {
        "value": "{primitive.lenovo.secondary.600}",
        "type": "color",
        "description": "Lenovo: secondary control border/text."
      },
      "secondaryHover": {
        "value": "{primitive.lenovo.secondary.900}",
        "type": "color",
        "description": "Lenovo: secondary hover emphasis."
      },
      "secondarySubtle": {
        "value": "{primitive.lenovo.secondary.50}",
        "type": "color",
        "description": "Lenovo: secondary ghost fill."
      },
      "disabled": {
        "value": "{primitive.lenovo.neutral.200}",
        "type": "color",
        "description": "Lenovo: disabled control fill."
      },
      "disabledText": {
        "value": "{primitive.lenovo.neutral.400}",
        "type": "color",
        "description": "Lenovo: disabled control label."
      }
    },
    "feedback": {
      "error": {
        "value": "{primitive.lenovo.accent.600}",
        "type": "color",
        "description": "Lenovo: error border/icon."
      },
      "errorSubtle": {
        "value": "{primitive.lenovo.accent.50}",
