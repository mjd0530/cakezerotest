        "value": "{primitive.lenovo.accent.300}",
        "type": "color",
        "description": "Lenovo: warning accent (coral)."
      },
      "muted": {
        "value": "{primitive.lenovo.accent.100}",
        "type": "color",
        "description": "Lenovo: warning backgrounds."
      },
      "onWarning": {
        "value": "{primitive.lenovo.accent.700}",
        "type": "color",
        "description": "Lenovo: warning text on muted fills."
      }
    },
    "danger": {
      "default": {
        "value": "{primitive.lenovo.accent.600}",
        "type": "color",
        "description": "Lenovo: destructive actions, errors — red allowed only here and feedback.error (not for primary UI)."
      },
      "hover": {
        "value": "{primitive.lenovo.accent.700}",
        "type": "color",
        "description": "Lenovo: danger hover."
      },
      "muted": {
        "value": "{primitive.lenovo.accent.50}",
        "type": "color",
        "description": "Lenovo: error backgrounds."
      },
      "onDanger": {
        "value": "{primitive.common.white}",
        "type": "color",
        "description": "Text/icons on danger fill."
      }
    },
    "border": {
